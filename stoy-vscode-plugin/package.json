{
    "name": "stoy-language",
    "displayName": "Stoy Shader Language",
    "description": "Language support for .stoy shader description files — syntax highlighting, auto-completion, hover, go-to-definition, diagnostics, and HLSL intelligence via request forwarding",
    "version": "2.0.0",
    "publisher": "onemore",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/onemore/ai-ShaderToy"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "onLanguage:stoy"
    ],
    "main": "./out/client.js",
    "contributes": {
        "configuration": {
            "title": "Stoy Shader",
            "properties": {
                "stoy.hlsl.provider": {
                    "type": "string",
                    "enum": [
                        "builtin",
                        "externalLsp"
                    ],
                    "default": "builtin",
                    "markdownDescription": "选择 HLSL 智能提示方案：\n- **builtin**：内置正则方案（默认），使用内置函数签名库 + 正则符号扫描\n- **externalLsp**：外部 LSP 方案，通过虚拟文档将 HLSL 请求转发给外部 HLSL 扩展（如 shader-validator）\n\n切换后需要重载窗口生效。"
                }
            }
        },
        "languages": [
            {
                "id": "stoy",
                "aliases": [
                    "Stoy Shader",
                    "stoy"
                ],
                "extensions": [
                    ".stoy"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "stoy",
                "scopeName": "source.stoy",
                "path": "./syntaxes/stoy.tmLanguage.json",
                "embeddedLanguages": {
                    "meta.embedded.block.hlsl.stoy": "hlsl"
                }
            }
        ]
    },
    "scripts": {
        "build": "node esbuild.js",
        "watch": "node esbuild.js --watch",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/node": "^18.0.0",
        "@types/vscode": "^1.75.0",
        "esbuild": "^0.20.0",
        "typescript": "^5.3.0"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.0",
        "vscode-languageserver": "^9.0.0",
        "vscode-languageserver-textdocument": "^1.0.0"
    }
}
